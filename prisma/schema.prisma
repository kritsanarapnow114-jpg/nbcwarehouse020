// NBC Warehouse — data model
// See /root/.claude/plans/abstract-roaming-hummingbird.md for the full plan.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  RAW_MATERIAL
  PACKAGING
  FINISHED_GOODS
  SPARE_PARTS
}

enum Zone {
  A
  B
  C
  D
  E
}

enum LotStatus {
  OK
  QC
}

enum ReceiptMode {
  PO
  PRODUCTION
}

enum POStatus {
  OPEN
  PENDING
  COMPLETE
}

enum AdjustReason {
  COUNT_VARIANCE
  DAMAGED
  EXPIRED
  QC_REJECT
}

enum KpiKey {
  SAFETY
  COST
  DELIVERY
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  name           String
  role           String   @default("Warehouse Lead")
  avatarInitials String   @default("U")
  createdAt      DateTime @default(now())
}

model Product {
  code        String    @id
  nameEn      String
  nameTh      String?
  category    Category
  unit        String
  price       Float
  pallet      Int       @default(500)
  width       Float // storage footprint, m
  length      Float // storage footprint, m
  stackLevels Int       @default(1)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lots           Lot[]
  poLines        PurchaseOrderLine[]
  receiptLines   ReceiptLine[]
  issueLines     IssueLine[]
  bom            Bom?                @relation("FinishedProduct")
  usedInBomLines BomLine[]           @relation("MaterialProduct")

  @@index([category])
}

model Location {
  code   String @id
  zone   Zone
  width  Float // m
  length Float // m

  lots Lot[]

  @@index([zone])
}

model Lot {
  id           String    @id @default(cuid())
  productCode  String
  product      Product   @relation(fields: [productCode], references: [code])
  locationCode String
  location     Location  @relation(fields: [locationCode], references: [code])
  lotNo        String // "-" sentinel = not lot-tracked (spare parts)
  qty          Float
  status       LotStatus @default(OK)
  recvDate     DateTime
  mfgDate      DateTime?
  expDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  receiptLines         ReceiptLine[]
  issueLinesFefo       IssueLine[]                  @relation("FefoLot")
  issueLinesSel        IssueLine[]                  @relation("SelectedLot")
  adjustmentLines      AdjustmentLine[]
  transferLinesOut     TransferLine[]
  stockCountLines      StockCountLine[]
  materialConsumptions ReceiptMaterialConsumption[]

  @@index([productCode])
  @@index([locationCode])
  @@index([status])
  @@index([expDate])
}

model PurchaseOrder {
  id     String              @id @default(cuid())
  no     String              @unique
  vendor String
  date   DateTime
  status POStatus            @default(OPEN)
  lines  PurchaseOrderLine[]

  receipts Receipt[]

  @@index([status])
}

model PurchaseOrderLine {
  id          String        @id @default(cuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  productCode String
  product     Product       @relation(fields: [productCode], references: [code])
  ordered     Float
  received    Float         @default(0)
}

model Receipt {
  id            String         @id @default(cuid())
  docNo         String         @unique
  mode          ReceiptMode
  poId          String?
  po            PurchaseOrder? @relation(fields: [poId], references: [id])
  invoiceNo     String? // only meaningful when mode = PO
  docDate       DateTime
  producedTotal Float? // mode = PRODUCTION
  prodLoss      Float? // mode = PRODUCTION, finished-goods loss qty
  reversedAt    DateTime? // set when the document is reversed/voided
  createdAt     DateTime       @default(now())

  lines               ReceiptLine[]
  bomLoss             ReceiptBomLoss[]
  materialConsumption ReceiptMaterialConsumption[]

  @@index([mode])
  @@index([docDate])
}

model ReceiptLine {
  id           String    @id @default(cuid())
  receiptId    String
  receipt      Receipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  productCode  String
  product      Product   @relation(fields: [productCode], references: [code])
  orderedQty   Float?
  recvQty      Float
  lotNo        String
  locationCode String
  mfgDate      DateTime?
  expDate      DateTime?
  lotId        String?
  lot          Lot?      @relation(fields: [lotId], references: [id])
}

model Bom {
  id                  String    @id @default(cuid())
  finishedProductCode String    @unique
  finishedProduct     Product   @relation("FinishedProduct", fields: [finishedProductCode], references: [code])
  lines               BomLine[]
}

model BomLine {
  id                  String  @id @default(cuid())
  bomId               String
  bom                 Bom     @relation(fields: [bomId], references: [id], onDelete: Cascade)
  materialProductCode String
  materialProduct     Product @relation("MaterialProduct", fields: [materialProductCode], references: [code])
  qtyPerUnit          Float
  perQty              Float   @default(1) // consume qtyPerUnit for every `perQty` finished units produced (e.g. 1 pallet per 750 kg)
  unit                String

  receiptLoss ReceiptBomLoss[]
}

model ReceiptBomLoss {
  id        String  @id @default(cuid())
  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  bomLineId String
  bomLine   BomLine @relation(fields: [bomLineId], references: [id])
  lossQty   Float
}

/** Per-lot record of raw material actually deducted by a production receipt,
 *  so reversing the receipt can add the exact quantities back to the same lots. */
model ReceiptMaterialConsumption {
  id        String  @id @default(cuid())
  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  lotId     String
  lot       Lot     @relation(fields: [lotId], references: [id])
  qty       Float
}

model Issue {
  id          String    @id @default(cuid())
  docNo       String    @unique
  issueTo     String // "Production - Line A" | "Production - Line B" | "Wholesale - Customer" | "Write-off"
  docDate     DateTime
  shippedDate DateTime? // actual ship date, drives Delivery on-time KPI
  reversedAt  DateTime? // set when the document is reversed/voided
  createdAt   DateTime  @default(now())

  lines IssueLine[]

  @@index([docDate])
}

model IssueLine {
  id            String  @id @default(cuid())
  issueId       String
  issue         Issue   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  productCode   String
  product       Product @relation(fields: [productCode], references: [code])
  fefoLotId     String?
  fefoLot       Lot?    @relation("FefoLot", fields: [fefoLotId], references: [id])
  selectedLotId String
  selectedLot   Lot     @relation("SelectedLot", fields: [selectedLotId], references: [id])
  qty           Float
}

model Adjustment {
  id         String       @id @default(cuid())
  docNo      String       @unique
  reason     AdjustReason @default(COUNT_VARIANCE)
  docDate    DateTime
  reversedAt DateTime? // set when the document is reversed/voided

  lines AdjustmentLine[]
}

model AdjustmentLine {
  id           String     @id @default(cuid())
  adjustmentId String
  adjustment   Adjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  lotId        String
  lot          Lot        @relation(fields: [lotId], references: [id])
  sysQty       Float
  countedQty   Float
}

model Transfer {
  id         String    @id @default(cuid())
  docNo      String    @unique
  operator   String
  docDate    DateTime
  reversedAt DateTime? // set when the document is reversed/voided

  lines TransferLine[]
}

model TransferLine {
  id               String   @id @default(cuid())
  transferId       String
  transfer         Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  lotId            String
  lot              Lot      @relation(fields: [lotId], references: [id])
  fromLocationCode String
  toLocationCode   String
  qty              Float
}

model StockCount {
  id         String    @id @default(cuid())
  docNo      String    @unique
  pullZone   String // "All zones" | "Zone A - Raw Material" | ...
  docDate    DateTime
  reversedAt DateTime? // set when the document is reversed/voided

  lines StockCountLine[]
}

model StockCountLine {
  id           String     @id @default(cuid())
  stockCountId String
  stockCount   StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  lotId        String
  lot          Lot        @relation(fields: [lotId], references: [id])
  sysQty       Float
  countedQty   Float
  addedQty     Float      @default(0) // stock this line actually added (off-system finds); 0 for plain counts
}

model DocSequence {
  id      String @id @default(cuid())
  prefix  String
  beYear  Int
  lastSeq Int    @default(0)

  @@unique([prefix, beYear])
}

/** Marks one-time seed steps (e.g. a bulk product import) as already applied,
 *  so re-running seed on every deploy doesn't re-create rows the user deleted. */
model SeedFlag {
  key       String   @id
  appliedAt DateTime @default(now())
}

/** Generic editable key-value settings (page subtitles, stock-count plan
 *  targets, etc.) so non-code text/config can be changed from the UI. */
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model KpiLog {
  id         String   @id @default(cuid())
  key        KpiKey
  date       DateTime
  detail     String?
  amount     Float? // COST
  incident   Boolean? // SAFETY (false = baseline/reset entry, not a real incident)
  issueDocNo String? // DELIVERY
  onTime     Boolean? // DELIVERY
  createdAt  DateTime @default(now())

  @@index([key])
}
